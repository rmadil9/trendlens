OPENAI_API_KEY=sk-...

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=trendlens

SQLITE_PATH=./data/trendlens.db

# Ingestion tuning
FETCH_INTERVAL_MINUTES=60
MAX_ARTICLES_PER_FEED=20
MAX_ARTICLES_PER_RUN=5   # hard cap on new articles inserted per cron run (cost control)

# Retrieval tuning
RETRIEVAL_K=5
DEFAULT_WINDOW_DAYS=30
